## 8. Analyzer Screen
```typescript
// src/screens/AnalyzerScreen.tsx
import React, { useState } from 'react';
import {
  View,
  Text,
  StyleSheet,
  TouchableOpacity,
  Alert,
  ActivityIndicator,
} from 'react-native';
import DocumentPicker from 'react-native-document-picker';
import { resumeAPI } from '../api/apiService';
import Icon from 'react-native-vector-icons/MaterialIcons';

const AnalyzerScreen = () => {
  const [selectedFile, setSelectedFile] = useState<any>(null);
  const [analyzing, setAnalyzing] = useState(false);
  const [analysis, setAnalysis] = useState<any>(null);

  const selectFile = async () => {
    try {
      const result = await DocumentPicker.pick({
        type: [DocumentPicker.types.pdf, DocumentPicker.types.docx],
      });
      setSelectedFile(result[0]);
    } catch (err) {
      if (DocumentPicker.isCancel(err)) {
        // User cancelled
      } else {
        Alert.alert('Error', 'Failed to select file');
      }
    }
  };

  const analyzeResume = async () => {
    if (!selectedFile) {
      Alert.alert('Error', 'Please select a resume file');
      return;
    }

    setAnalyzing(true);
    try {
      // Convert file to format expected by API
      const formData = new FormData();
      formData.append('file', {
        uri: selectedFile.uri,
        type: selectedFile.type,
        name: selectedFile.name,
      });

      const result = await resumeAPI.analyzeResume(formData);
      setAnalysis(result);
    } catch (error) {
      Alert.alert('Error', 'Failed to analyze resume');
    } finally {
      setAnalyzing(false);
    }
  };

  return (
    <View style={styles.container}>
      <View style={styles.header}>
        <Text style={styles.title}>Resume Analyzer</Text>
        <Text style={styles.subtitle}>Get AI-powered insights</Text>
      </View>

      <View style={styles.content}>
        <TouchableOpacity style={styles.uploadButton} onPress={selectFile}>
          <Icon name="cloud-upload" size={48} color="#667eea" />
          <Text style={styles.uploadText}>
            {selectedFile ? selectedFile.name : 'Select Resume File'}
          </Text>
          <Text style={styles.uploadSubtext}>PDF or DOCX</Text>
        </TouchableOpacity>

        {selectedFile && (
          <TouchableOpacity
            style={[styles.analyzeButton, analyzing && styles.disabledButton]}
            onPress={analyzeResume}
            disabled={analyzing}
          >
            {analyzing ? (
              <ActivityIndicator color="white" />
            ) : (
              <Text style={styles.analyzeText}>Analyze Resume</Text>
            )}
          </TouchableOpacity>
        )}

        {analysis && (
          <View style={styles.resultsContainer}>
            <Text style={styles.resultsTitle}>Analysis Results</Text>
            
            <View style={styles.metricsContainer}>
              <View style={styles.metric}>
                <Text style={styles.metricValue}>{analysis.atsScore}</Text>
                <Text style={styles.metricLabel}>ATS Score</Text>
              </View>
              <View style={styles.metric}>
                <Text style={styles.metricValue}>{analysis.skillsMatch}%</Text>
                <Text style={styles.metricLabel}>Skills Match</Text>
              </View>
              <View style={styles.metric}>
                <Text style={styles.metricValue}>{analysis.grade}</Text>
                <Text style={styles.metricLabel}>Grade</Text>
              </View>
            </View>

            <View style={styles.skillsContainer}>
              <Text style={styles.skillsTitle}>Detected Skills</Text>
              {analysis.skills.technical.map((skill: string, index: number) => (
                <View key={index} style={styles.skillTag}>
                  <Text style={styles.skillText}>{skill}</Text>
                </View>
              ))}
            </View>
          </View>
        )}
      </View>
    </View>
  );
};

